Panels:
  - Class: rviz/Displays
    Help Height: 70
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /TF1/TF1
        - /Perception1
        - /Perception1/TrackObjects1
        - /Perception1/TrackObjects1/Namespaces1
        - /ML-based Planning1
      Splitter Ratio: 0.618677020072937
    Tree Height: 431
  - Class: rviz/Selection
    Name: Selection
  - Class: rviz/Tool Properties
    Expanded:
      - /2D Pose Estimate1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.5886790156364441
  - Class: rviz/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz/Time
    Name: Time
    SyncMode: 0
    SyncSource: ""
Preferences:
  PromptSaveOnExit: true
Toolbars:
  toolButtonStyle: 2
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 1
      Cell Size: 200
      Class: rviz/Grid
      Color: 255; 255; 0
      Enabled: false
      Line Style:
        Line Width: 0.029999999329447746
        Value: Lines
      Name: Grid (Map Boundary)
      Normal Cell Count: 0
      Offset:
        X: 0
        Y: 0
        Z: 0
      Plane: XY
      Plane Cell Count: 1
      Reference Frame: ego_frame
      Value: false
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /hmi/dae_ego_vehicle
      Name: EgoVehicle
      Namespaces:
        IONIQ 5: true
      Queue Size: 100
      Value: true
    - Class: rviz/Group
      Displays:
        - Class: rviz/TF
          Enabled: true
          Filter (blacklist): ""
          Filter (whitelist): ""
          Frame Timeout: 15
          Frames:
            All Enabled: true
            ego_frame:
              Value: true
            ego_mesh:
              Value: true
            world:
              Value: true
          Marker Alpha: 1
          Marker Scale: 4
          Name: TF
          Show Arrows: false
          Show Axes: true
          Show Names: true
          Tree:
            world:
              ego_frame:
                ego_mesh:
                  {}
          Update Interval: 0
          Value: true
        - Class: jsk_rviz_plugin/TFTrajectory
          Enabled: true
          Name: TFTrajectory
          Value: true
          color: 25; 255; 240
          duration: 10
          frame: ego_frame
          line_width: 0.009999999776482582
      Enabled: true
      Name: TF
    - Class: rviz/Group
      Displays:
        - Class: rviz/MarkerArray
          Enabled: true
          Marker Topic: /hmi/perc/track_objects
          Name: TrackObjects
          Namespaces:
            position: true
            velocity: true
          Queue Size: 100
          Value: true
        - Class: rviz/MarkerArray
          Enabled: true
          Marker Topic: /hmi/perc/predict_objects
          Name: PredictObjects
          Namespaces:
            position: false
            reference: false
            track_info: true
          Queue Size: 100
          Value: true
        - Class: rviz/MarkerArray
          Enabled: false
          Marker Topic: /hmi/perc/track_objects_heading
          Name: Heading
          Namespaces:
            {}
          Queue Size: 100
          Value: false
      Enabled: true
      Name: Perception
    - Class: rviz/Group
      Displays:
        - Class: rviz/MarkerArray
          Enabled: true
          Marker Topic: /hmi/pla/map
          Name: LaneletMap
          Namespaces:
            cube: true
            line: true
          Queue Size: 100
          Value: true
        - Class: rviz/MarkerArray
          Enabled: false
          Marker Topic: /hmi/pla/shortest_path
          Name: ShortestPath
          Namespaces:
            {}
          Queue Size: 100
          Value: false
        - Alpha: 1
          Class: rviz/PointStamped
          Color: 204; 41; 204
          Enabled: true
          History Length: 1
          Name: GoalPoint
          Queue Size: 10
          Radius: 1
          Topic: /app/pla/goal_point
          Unreliable: false
          Value: true
        - Class: rviz/MarkerArray
          Enabled: false
          Marker Topic: /hmi/pla/goal_points
          Name: GoalPoints
          Namespaces:
            {}
          Queue Size: 100
          Value: false
        - Class: rviz/MarkerArray
          Enabled: false
          Marker Topic: /hmi/pla/route_num
          Name: RouteNum
          Namespaces:
            {}
          Queue Size: 100
          Value: false
        - Class: rviz/MarkerArray
          Enabled: false
          Marker Topic: /hmi/pla/global_route
          Name: Route
          Namespaces:
            {}
          Queue Size: 100
          Value: false
        - Class: rviz/MarkerArray
          Enabled: false
          Marker Topic: /hmi/pla/route_points
          Name: RoutePoints
          Namespaces:
            {}
          Queue Size: 100
          Value: false
      Enabled: true
      Name: Global Planning
    - Class: rviz/Group
      Displays:
        - Class: rviz/MarkerArray
          Enabled: true
          Marker Topic: /hmi/pla/planning_space
          Name: "[Input] PlanningSpace"
          Namespaces:
            dividing_lane: true
            ego: false
            goal_routes: true
            lane: true
            left_boundary: false
            object: false
            right_boundary: false
            route: true
          Queue Size: 100
          Value: true
        - Class: rviz/MarkerArray
          Enabled: true
          Marker Topic: /hmi/pla/trajectory_ml
          Name: "[Output] ML Trajectory"
          Namespaces:
            curvature: false
            spatial: true
            temporal: false
            trajectory: true
          Queue Size: 100
          Value: true
      Enabled: true
      Name: ML-based Planning
    - Class: rviz/Group
      Displays:
        - Align Bottom: false
          Background Alpha: 0
          Background Color: 0; 0; 0
          Class: jsk_rviz_plugin/OverlayText
          Enabled: true
          Foreground Alpha: 0.800000011920929
          Foreground Color: 25; 255; 240
          Invert Shadow: false
          Name: Evaluation Result
          Overtake BG Color Properties: true
          Overtake FG Color Properties: true
          Overtake Position Properties: true
          Topic: /app/eval/result
          Value: true
          font: DejaVu Sans Mono
          height: 800
          left: 30
          line width: 2
          text size: 10
          top: 0
          width: 600
        - Class: rviz/MarkerArray
          Enabled: false
          Marker Topic: /drivable_area
          Name: DrivableArea
          Namespaces:
            {}
          Queue Size: 100
          Value: false
      Enabled: true
      Name: Evaluation
  Enabled: true
  Global Options:
    Background Color: 48; 48; 48
    Default Light: true
    Fixed Frame: world
    Frame Rate: 100
  Name: root
  Tools:
    - Class: rviz/Interact
      Hide Inactive Objects: true
    - Class: rviz/MoveCamera
    - Class: rviz/Select
    - Class: rviz/FocusCamera
    - Class: rviz/Measure
    - Class: rviz/SetInitialPose
      Theta std deviation: 0.2617993950843811
      Topic: /initialpose
      X std deviation: 0.5
      Y std deviation: 0.5
    - Class: rviz/SetGoal
      Topic: /move_base_simple/goal
    - Class: rviz/PublishPoint
      Single click: true
      Topic: /clicked_point
  Value: true
  Views:
    Current:
      Angle: 0
      Class: rviz/TopDownOrtho
      Enable Stereo Rendering:
        Stereo Eye Separation: 0.05999999865889549
        Stereo Focal Distance: 1
        Swap Stereo Eyes: false
        Value: false
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.009999999776482582
      Scale: 7.1589436531066895
      Target Frame: ego_frame
      X: -5.664255142211914
      Y: 15.004966735839844
    Saved:
      - Angle: -0.49499988555908203
        Class: rviz/TopDownOrtho
        Enable Stereo Rendering:
          Stereo Eye Separation: 0.05999999865889549
          Stereo Focal Distance: 1
          Swap Stereo Eyes: false
          Value: false
        Invert Z Axis: false
        Name: recordview
        Near Clip Distance: 0.009999999776482582
        Scale: 6.926270008087158
        Target Frame: ego_frame
        X: 18.94332504272461
        Y: 32.93864440917969
Window Geometry:
  Displays:
    collapsed: false
  Height: 752
  Hide Left Dock: false
  Hide Right Dock: false
  QMainWindow State: 
  Selection:
    collapsed: false
  Time:
    collapsed: false
  Tool Properties:
    collapsed: false
  Views:
    collapsed: false
  Width: 1386
  X: 534
  Y: 69
